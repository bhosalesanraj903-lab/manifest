", "compiled": true, "compiled_code": "-- Row-count reconciliation: the fact table must match silver exactly.\n-- Any drift fails the build (requirement R9).\nselect 'fct_shipment_events row count != stg_shipment_events' as failure\nwhere (select count(*) from \"manifest\".\"main\".\"fct_shipment_events\")\n   <> (select count(*) from \"manifest\".\"main\".\"stg_shipment_events\")", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-21T19:28:02.507575Z", "completed_at": "2026-07-21T19:28:02.508474Z"}, {"name": "execute", "started_at": "2026-07-21T19:28:02.509829Z", "completed_at": "2026-07-21T19:28:02.522642Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.016541004180908203, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.manifest.eta_baseline", "compiled": true, "compiled_code": "-- Median planned-vs-actual offset per lane + carrier + milestone.\n-- Consumed by eta/predict.py (R10) as the baseline adjustment.\nselect\n    carrier,\n    lane,\n    event_type,\n    count(*) as observations,\n    round(median(delay_hours), 2) as median_offset_h\nfrom \"manifest\".\"main\".\"fct_shipment_events\"\ngroup by 1, 2, 3\norder by 1, 2, 3", "relation_name": "\"manifest\".\"main\".\"eta_baseline\"", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-21T19:28:02.506618Z", "completed_at": "2026-07-21T19:28:02.508366Z"}, {"name": "execute", "started_at": "2026-07-21T19:28:02.508586Z", "completed_at": "2026-07-21T19:28:02.528136Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.02212691307067871, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.manifest.carrier_scorecard", "compiled": true, "compiled_code": "-- Carrier/lane operational scorecard:\n--   on_time_pct        delivered within 24h of plan\n--   mis_scan_rate      shipments that went dark (MISSED_MILESTONE) / shipments\n--   avg_customs_dwell_h  vessel_arrived -> customs_release\nwith shipments as (\n    select carrier, lane, shipment_id\n    from \"manifest\".\"main\".\"fct_shipment_events\"\n    group by 1, 2, 3\n),\n\ndelivered as (\n    select carrier, lane, shipment_id,\n           max(case when delay_hours <= 24 then 1 else 0 end) as on_time\n    from \"manifest\".\"main\".\"fct_shipment_events\"\n    where event_type = 'delivered'\n    group by 1, 2, 3\n),\n\ndark as (\n    select shipment_id\n    from \"manifest\".\"main\".\"stg_exception_queue\"\n    where exception_type = 'MISSED_MILESTONE'\n),\n\ncustoms as (\n    select\n        carrier, lane, shipment_id,\n        date_diff('minute',\n                  max(case when event_type = 'vessel_arrived' then actual_ts end),\n                  max(case when event_type = 'customs_release' then actual_ts end)\n        ) / 60.0 as customs_dwell_h\n    from \"manifest\".\"main\".\"fct_shipment_events\"\n    where event_type in ('vessel_arrived', 'customs_release')\n    group by 1, 2, 3\n    having count(distinct event_type) = 2\n)\n\nselect\n    s.carrier,\n    s.lane,\n    count(distinct s.shipment_id) as shipments,\n    round(100.0 * avg(d.on_time), 1) as on_time_pct,\n    round(100.0 * avg(case when k.shipment_id is not null then 1.0 else 0.0 end), 1)\n        as mis_scan_rate,\n    round(avg(c.customs_dwell_h), 1) as avg_customs_dwell_h\nfrom shipments s\nleft join delivered d using (carrier, lane, shipment_id)\nleft join dark k on k.shipment_id = s.shipment_id\nleft join customs c using (carrier, lane, shipment_id)\ngroup by 1, 2\norder by 1, 2", "relation_name": "\"manifest\".\"main\".\"carrier_scorecard\"", "batch_results": null, "overload_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-07-21T19:28:02.529296Z", "completed_at": "2026-07-21T19:28:02.531821Z"}, {"name": "execute", "started_at": "2026-07-21T19