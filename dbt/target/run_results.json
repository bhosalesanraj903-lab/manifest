, "message": "OK", "failures": null, "unique_id": "model.manifest.fct_shipment_events", "compiled": true, "compiled_code": "select\n    e.event_id,\n    e.shipment_id,\n    e.carrier,\n    c.carrier_name,\n    e.event_type,\n    e.planned_ts,\n    e.actual_ts,\n    date_diff('minute', e.planned_ts, e.actual_ts) / 60.0 as delay_hours,\n    e.origin,\n    lo.port_name as origin_name,\n    e.dest,\n    ld.port_name as dest_name,\n    e.origin || '-' || e.dest as lane,\n    e.vessel_mmsi\nfrom \"manifest\".\"main\".\"stg_shipment_events\" e\nleft join \"manifest\".\"main\".\"dim_carrier\" c on c.carrier_code = e.carrier\nleft join \"manifest\".\"main\".\"dim_location\" lo on lo.unlocode = e.origin\nleft join \"manifest\".\"main\".\"dim_location\" ld on ld.unlocode = e.dest", "relation_name": "\"manifest\".\"main\".\"fct_shipment_events\"", "batch_results": null, "overload_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-07-21T19:28:02.385317Z", "completed_at": "2026-07-21T19:28:02.399584Z"}, {"name": "execute", "started_at": "2026-07-21T19:28:02.400408Z", "completed_at": "2026-07-21T19:28:02.405966Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.024932861328125, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.manifest.not_null_fct_shipment_events_event_id.f5c1d38f6d", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect event_id\nfrom \"manifest\".\"main\".\"fct_shipment_events\"\nwhere event_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-07-21T19:28:02.387314Z", "completed_at": "2026-07-21T19:28:02.400983Z"}, {"name": "execute", "started_at": "2026-07-21T19:28:02.401671Z", "completed_at": "2026-07-21T19:28:02.407259Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.026762962341308594, "adapter_response": {"_message": "OK"}, "message": null, "failu